// © Lunarcy7

//@version=6
indicator("EMA Clouds", "Clouds", overlay = true)

//────────────────────────────
// Core Inputs
//────────────────────────────
matype   = input.string(title = "MA Type", defval = "EMA", options = ["EMA", "SMA"])

ma_len1  = input.int(title = "Short EMA1 Length", defval = 8)
ma_len2  = input.int(title = "Long  EMA1 Length", defval = 9)
ma_len3  = input.int(title = "Short EMA2 Length", defval = 5)
ma_len4  = input.int(title = "Long  EMA2 Length", defval = 12)
ma_len5  = input.int(title = "Short EMA3 Length", defval = 34)
ma_len6  = input.int(title = "Long  EMA3 Length", defval = 50)
ma_len7  = input.int(title = "Short EMA4 Length", defval = 72)
ma_len8  = input.int(title = "Long  EMA4 Length", defval = 89)
ma_len9  = input.int(title = "Short EMA5 Length", defval = 180)
ma_len10 = input.int(title = "Long  EMA5 Length", defval = 200)

src       = input.source(title = "Source", defval = hl2)
ma_offset = input.int(title = "Offset", defval = 0)

//────────────────────────────
// MA function
//────────────────────────────
f_ma(malen) =>
    float result = na
    if matype == "EMA"
        result := ta.ema(src, malen)
    if matype == "SMA"
        result := ta.sma(src, malen)
    result

htf_ma1  = f_ma(ma_len1)
htf_ma2  = f_ma(ma_len2)
htf_ma3  = f_ma(ma_len3)
htf_ma4  = f_ma(ma_len4)
htf_ma5  = f_ma(ma_len5)
htf_ma6  = f_ma(ma_len6)
htf_ma7  = f_ma(ma_len7)
htf_ma8  = f_ma(ma_len8)
htf_ma9  = f_ma(ma_len9)
htf_ma10 = f_ma(ma_len10)

//────────────────────────────
// Display / cloud toggles
//────────────────────────────
showlong   = input.bool(false, title = "Show Long Alerts")
showshort  = input.bool(false, title = "Show Short Alerts")
showLine   = input.bool(false, title = "Display EMA Line")

ema1 = input.bool(true,  title = "Show EMA Cloud-1")
ema2 = input.bool(true,  title = "Show EMA Cloud-2")
ema3 = input.bool(true,  title = "Show EMA Cloud-3")
ema4 = input.bool(false, title = "Show EMA Cloud-4")
ema5 = input.bool(false, title = "Show EMA Cloud-5")

emacloudleading = input.int(0, minval = 0, title = "Leading Period For EMA Cloud")

mashort1 = htf_ma1
malong1  = htf_ma2
mashort2 = htf_ma3
malong2  = htf_ma4
mashort3 = htf_ma5
malong3  = htf_ma6
mashort4 = htf_ma7
malong4  = htf_ma8
mashort5 = htf_ma9
malong5  = htf_ma10

//────────────────────────────
// Cloud Color & Transparency Inputs
//────────────────────────────
// Cloud 1
cloud1BullColor = input.color(title = "Cloud 1 Bull Color", defval = #036103)
cloud1BearColor = input.color(title = "Cloud 1 Bear Color", defval = #880e4f)
cloud1Trans     = input.int(title = "Cloud 1 Transparency (0-100)", defval = 45, minval = 0, maxval = 100)

// Cloud 2
cloud2BullColor = input.color(title = "Cloud 2 Bull Color", defval = #4caf50)
cloud2BearColor = input.color(title = "Cloud 2 Bear Color", defval = #f44336)
cloud2Trans     = input.int(title = "Cloud 2 Transparency (0-100)", defval = 65, minval = 0, maxval = 100)

// Cloud 3
cloud3BullColor = input.color(title = "Cloud 3 Bull Color", defval = #2196f3)
cloud3BearColor = input.color(title = "Cloud 3 Bear Color", defval = #ffb74d)
cloud3Trans     = input.int(title = "Cloud 3 Transparency (0-100)", defval = 70, minval = 0, maxval = 100)

// Cloud 4
cloud4BullColor = input.color(title = "Cloud 4 Bull Color", defval = #009688)
cloud4BearColor = input.color(title = "Cloud 4 Bear Color", defval = #f06292)
cloud4Trans     = input.int(title = "Cloud 4 Transparency (0-100)", defval = 65, minval = 0, maxval = 100)

// Cloud 5
cloud5BullColor = input.color(title = "Cloud 5 Bull Color", defval = #05bed5)
cloud5BearColor = input.color(title = "Cloud 5 Bear Color", defval = #e65100)
cloud5Trans     = input.int(title = "Cloud 5 Transparency (0-100)", defval = 65, minval = 0, maxval = 100)

// Conditional cloud colors (bull vs bear)
cloudcolour1 = mashort1 >= malong1 ? cloud1BullColor : cloud1BearColor
cloudcolour2 = mashort2 >= malong2 ? cloud2BullColor : cloud2BearColor
cloudcolour3 = mashort3 >= malong3 ? cloud3BullColor : cloud3BearColor
cloudcolour4 = mashort4 >= malong4 ? cloud4BullColor : cloud4BearColor
cloudcolour5 = mashort5 >= malong5 ? cloud5BullColor : cloud5BearColor

//────────────────────────────
// Line Colors
//────────────────────────────
mashortcolor1 = mashort1 >= mashort1[1] ? color.olive             : color.maroon
mashortcolor2 = mashort2 >= mashort2[1] ? color.olive             : color.maroon
mashortcolor3 = mashort3 >= mashort3[1] ? color.olive             : color.maroon
mashortcolor4 = mashort4 >= mashort4[1] ? color.olive             : color.maroon
mashortcolor5 = mashort5 >= mashort5[1] ? color.rgb(179, 179, 43) : color.maroon

mashortline1 = plot(ema1 ? mashort1 : na, color = showLine ? mashortcolor1 : na, linewidth = 1, offset = emacloudleading, title = "Short Leading EMA1")
mashortline2 = plot(ema2 ? mashort2 : na, color = showLine ? mashortcolor2 : na, linewidth = 1, offset = emacloudleading, title = "Short Leading EMA2")
mashortline3 = plot(ema3 ? mashort3 : na, color = showLine ? mashortcolor3 : na, linewidth = 1, offset = emacloudleading, title = "Short Leading EMA3")
mashortline4 = plot(ema4 ? mashort4 : na, color = showLine ? mashortcolor4 : na, linewidth = 1, offset = emacloudleading, title = "Short Leading EMA4")
mashortline5 = plot(ema5 ? mashort5 : na, color = showLine ? mashortcolor5 : na, linewidth = 1, offset = emacloudleading, title = "Short Leading EMA5")

malongcolor1 = malong1 >= malong1[1] ? color.green : color.red
malongcolor2 = malong2 >= malong2[1] ? color.green : color.red
malongcolor3 = malong3 >= malong3[1] ? color.green : color.red
malongcolor4 = malong4 >= malong4[1] ? color.green : color.red
malongcolor5 = malong5 >= malong5[1] ? color.green : color.red

malongline1 = plot(ema1 ? malong1 : na, color = showLine ? malongcolor1 : na, linewidth = 3, offset = emacloudleading, title = "Long Leading EMA1")
malongline2 = plot(ema2 ? malong2 : na, color = showLine ? malongcolor2 : na, linewidth = 3, offset = emacloudleading, title = "Long Leading EMA2")
malongline3 = plot(ema3 ? malong3 : na, color = showLine ? malongcolor3 : na, linewidth = 3, offset = emacloudleading, title = "Long Leading EMA3")
malongline4 = plot(ema4 ? malong4 : na, color = showLine ? malongcolor4 : na, linewidth = 3, offset = emacloudleading, title = "Long Leading EMA4")
malongline5 = plot(ema5 ? malong5 : na, color = showLine ? malongcolor5 : na, linewidth = 3, offset = emacloudleading, title = "Long Leading EMA5")

//────────────────────────────
// Clouds (with configurable transparency)
//────────────────────────────
fill(mashortline1, malongline1, color = color.new(cloudcolour1, cloud1Trans), title = "MA Cloud1")
fill(mashortline2, malongline2, color = color.new(cloudcolour2, cloud2Trans), title = "MA Cloud2")
fill(mashortline3, malongline3, color = color.new(cloudcolour3, cloud3Trans), title = "MA Cloud3")
fill(mashortline4, malongline4, color = color.new(cloudcolour4, cloud4Trans), title = "MA Cloud4")
fill(mashortline5, malongline5, color = color.new(cloudcolour5, cloud5Trans), title = "MA Cloud5")
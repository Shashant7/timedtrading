//@version=6
indicator("TimedTrading Levels Overlay", overlay=true, max_lines_count=500, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// Timed Trading — chart overlay for universe status, direction bias, stop,
// targets, and key S/R levels.
//
// Pine Script cannot call external HTTP APIs. Three modes:
//   1) GITHUB SEED — request.seed() from seed_timedtrading_levels repo
//        (data synced via scripts/sync-tv-levels-seed.mjs)
//   2) TT SYNC — paste the `compact` string from GET /timed/tv-levels
//   3) LOCAL — on-chart math (Unified-compatible bias + ATR levels)
// ─────────────────────────────────────────────────────────────────────────────

groupMode = "Data source"
dataMode = input.string("GitHub Seed (auto)", "Mode",
     options=["GitHub Seed (auto)", "TT Sync (paste compact string)", "Local (on-chart math)"],
     group=groupMode,
     tooltip="GitHub Seed pulls daily levels via request.seed (requires TV Pine Seeds fork). TT Sync pastes compact string. Local uses on-chart math.")
seedSource = input.string("seed_timedtrading_levels", "Seed repo name", group=groupMode,
     tooltip="Must match your Pine Seeds GitHub repository name exactly.")
ttSyncStr = input.string("", "TT Sync string (compact)", group=groupMode,
     tooltip="Paste the `compact` field from GET /timed/tv-levels?ticker=THIS_SYMBOL")

groupLocal = "Local mode tuning"
atrLen = input.int(14, "ATR length", minval=5, maxval=50, group=groupLocal)
atrStopMult = input.float(1.0, "Stop ATR multiple", minval=0.5, maxval=3.0, step=0.1, group=groupLocal)
tp1Mult = input.float(1.0, "Target 1 ATR multiple", minval=0.5, maxval=5.0, step=0.1, group=groupLocal)
tp2Mult = input.float(1.8, "Target 2 ATR multiple", minval=0.5, maxval=8.0, step=0.1, group=groupLocal)
tp3Mult = input.float(2.8, "Target 3 ATR multiple", minval=0.5, maxval=12.0, step=0.1, group=groupLocal)
pivotLen = input.int(5, "Pivot lookback", minval=3, maxval=15, group=groupLocal)

groupViz = "Visuals"
showTable = input.bool(true, "Show bias table", group=groupViz)
showStop = input.bool(true, "Show stop line", group=groupViz)
showTargets = input.bool(true, "Show target lines", group=groupViz)
showLevels = input.bool(true, "Show S/R levels", group=groupViz)
extendLines = input.bool(true, "Extend lines right", group=groupViz)

// ─────────────────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────────────────
f_toFloat(s) =>
    float out = na
    if str.length(s) > 0
        out := str.tonumber(s)
    out

f_field(parts, idx) =>
    array.size(parts) > idx ? array.get(parts, idx) : ""

f_roleColor(role) =>
    role == "S" ? color.new(color.teal, 0) : role == "R" ? color.new(color.orange, 0) : color.new(color.gray, 35)

f_dirColor(dir) =>
    dir == "LONG" ? color.new(color.teal, 0) : dir == "SHORT" ? color.new(color.red, 0) : color.new(color.gray, 0)

// Parse TTV1 compact: TTV1|in_univ|dir|bias|stage|rank|stop|tp1|tp2|tp3|levels
f_parse_sync(raw) =>
    string inUniv = "?"
    string dir = "NEUTRAL"
    string bias = "—"
    string stage = "—"
    string rankStr = "—"
    float stopPx = na
    float tp1 = na
    float tp2 = na
    float tp3 = na
    array<float> lvlPx = array.new_float()
    array<string> lvlLbl = array.new_string()
    array<string> lvlRole = array.new_string()
    bool ok = false
    if str.length(raw) > 10
        parts = str.split(raw, "|")
        if array.size(parts) >= 10 and f_field(parts, 0) == "TTV1"
            ok := true
            inUniv := f_field(parts, 1) == "1" ? "YES" : "NO"
            dir := f_field(parts, 2)
            bias := f_field(parts, 3)
            stage := f_field(parts, 4)
            rankStr := f_field(parts, 5)
            stopPx := f_toFloat(f_field(parts, 6))
            tp1 := f_toFloat(f_field(parts, 7))
            tp2 := f_toFloat(f_field(parts, 8))
            tp3 := f_toFloat(f_field(parts, 9))
            lvlBlob = f_field(parts, 10)
            if str.length(lvlBlob) > 0
                chunks = str.split(lvlBlob, ";")
                for i = 0 to array.size(chunks) - 1
                    chunk = array.get(chunks, i)
                    if str.length(chunk) > 0
                        sub = str.split(chunk, ":")
                        if array.size(sub) >= 2
                            px = f_toFloat(array.get(sub, 0))
                            lbl = array.get(sub, 1)
                            role = array.size(sub) >= 3 ? array.get(sub, 2) : "N"
                            if not na(px)
                                array.push(lvlPx, px)
                                array.push(lvlLbl, lbl)
                                array.push(lvlRole, role)
    [ok, inUniv, dir, bias, stage, rankStr, stopPx, tp1, tp2, tp3, lvlPx, lvlLbl, lvlRole]

// Decode Pine Seeds numeric codes (see worker/tv-levels-seed.js)
f_biasFromCode(c) =>
    int n = int(math.round(c))
    n == 1 ? "BULL_TREND" : n == 2 ? "BULL_PULLBACK" : n == 3 ? "BEAR_TREND" : n == 4 ? "BEAR_BOUNCE" : "NEUTRAL"

f_stageFromCode(c) =>
    int n = int(math.round(c))
    n == 1 ? "setup" : n == 2 ? "enter" : n == 3 ? "enter_now" : n == 4 ? "in_review" : n == 5 ? "defend" : n == 6 ? "trim" : n == 7 ? "exit" : "—"

f_dirFromCode(c) =>
    int n = int(math.round(c))
    n == 1 ? "LONG" : n == -1 ? "SHORT" : "NEUTRAL"

f_roleFromVol(v) =>
    int n = int(math.round(v))
    n == 1 ? "S" : n == 2 ? "R" : "N"

// GitHub Seed — symbol = chart ticker; OHLCV semantics documented in seed-timedtrading-levels/README.md
seedSym = str.upper(syminfo.ticker)
[seedPx, seedStop, seedTp1, seedTpRun, seedRank] = request.seed(seedSource, seedSym, [close, high, low, open, volume], ignore_invalid_symbol=true)
[seedDirC, seedInU, seedBiasC, seedStageC, seedMetaZ] = request.seed(seedSource, seedSym + "_META", [close, open, high, low, volume], ignore_invalid_symbol=true)
seedLv1 = request.seed(seedSource, seedSym + "_LV1", close, ignore_invalid_symbol=true)
seedLv2 = request.seed(seedSource, seedSym + "_LV2", close, ignore_invalid_symbol=true)
seedLv3 = request.seed(seedSource, seedSym + "_LV3", close, ignore_invalid_symbol=true)
seedLv4 = request.seed(seedSource, seedSym + "_LV4", close, ignore_invalid_symbol=true)
seedLv5 = request.seed(seedSource, seedSym + "_LV5", close, ignore_invalid_symbol=true)
seedLv6 = request.seed(seedSource, seedSym + "_LV6", close, ignore_invalid_symbol=true)
seedLv7 = request.seed(seedSource, seedSym + "_LV7", close, ignore_invalid_symbol=true)
seedLv8 = request.seed(seedSource, seedSym + "_LV8", close, ignore_invalid_symbol=true)
seedRv1 = request.seed(seedSource, seedSym + "_LV1", volume, ignore_invalid_symbol=true)
seedRv2 = request.seed(seedSource, seedSym + "_LV2", volume, ignore_invalid_symbol=true)
seedRv3 = request.seed(seedSource, seedSym + "_LV3", volume, ignore_invalid_symbol=true)
seedRv4 = request.seed(seedSource, seedSym + "_LV4", volume, ignore_invalid_symbol=true)
seedRv5 = request.seed(seedSource, seedSym + "_LV5", volume, ignore_invalid_symbol=true)
seedRv6 = request.seed(seedSource, seedSym + "_LV6", volume, ignore_invalid_symbol=true)
seedRv7 = request.seed(seedSource, seedSym + "_LV7", volume, ignore_invalid_symbol=true)
seedRv8 = request.seed(seedSource, seedSym + "_LV8", volume, ignore_invalid_symbol=true)

// ─────────────────────────────────────────────────────────────────────────────
// Local bias + levels (simplified Unified quadrant)
// ─────────────────────────────────────────────────────────────────────────────
tfD = "D"
tfW = "W"
tf30 = "30"

e21D = request.security(syminfo.tickerid, tfD, ta.ema(close, 21), barmerge.gaps_off, barmerge.lookahead_off)
e48D = request.security(syminfo.tickerid, tfD, ta.ema(close, 48), barmerge.gaps_off, barmerge.lookahead_off)
e21W = request.security(syminfo.tickerid, tfW, ta.ema(close, 21), barmerge.gaps_off, barmerge.lookahead_off)
e48W = request.security(syminfo.tickerid, tfW, ta.ema(close, 48), barmerge.gaps_off, barmerge.lookahead_off)
rsi30 = request.security(syminfo.tickerid, tf30, ta.rsi(close, 14), barmerge.gaps_off, barmerge.lookahead_off)

htfBull = e21W > e48W and e21D > e48D
htfBear = e21W < e48W and e21D < e48D
ltfBull = rsi30 > 55
ltfBear = rsi30 < 45

string localBias = "NEUTRAL"
string localDir = "NEUTRAL"
if htfBull and ltfBull
    localBias := "BULL_TREND"
    localDir := "LONG"
else if htfBull and ltfBear
    localBias := "BULL_PULLBACK"
    localDir := "LONG"
else if htfBear and ltfBear
    localBias := "BEAR_TREND"
    localDir := "SHORT"
else if htfBear and ltfBull
    localBias := "BEAR_BOUNCE"
    localDir := "SHORT"

atrD = request.security(syminfo.tickerid, tfD, ta.atr(atrLen), barmerge.gaps_off, barmerge.lookahead_off)
swingLo = request.security(syminfo.tickerid, tfD, ta.pivotlow(low, pivotLen, pivotLen), barmerge.gaps_off, barmerge.lookahead_off)
swingHi = request.security(syminfo.tickerid, tfD, ta.pivothigh(high, pivotLen, pivotLen), barmerge.gaps_off, barmerge.lookahead_off)

float localStop = na
float localTp1 = na
float localTp2 = na
float localTp3 = na
if localDir == "LONG"
    structStop = not na(swingLo) ? swingLo * 0.995 : close - atrStopMult * atrD
    localStop := math.min(structStop, close - 0.25 * atrD)
    localTp1 := close + tp1Mult * atrD
    localTp2 := close + tp2Mult * atrD
    localTp3 := close + tp3Mult * atrD
else if localDir == "SHORT"
    structStop = not na(swingHi) ? swingHi * 1.005 : close + atrStopMult * atrD
    localStop := math.max(structStop, close + 0.25 * atrD)
    localTp1 := close - tp1Mult * atrD
    localTp2 := close - tp2Mult * atrD
    localTp3 := close - tp3Mult * atrD

// ─────────────────────────────────────────────────────────────────────────────
// Resolve active values (seed > sync > local)
// ─────────────────────────────────────────────────────────────────────────────
useSeed = dataMode == "GitHub Seed (auto)"
useSync = dataMode == "TT Sync (paste compact string)"
seedOk = useSeed and not na(seedPx) and seedPx > 0
[syncOk, syncUniv, syncDir, syncBias, syncStage, syncRank, syncStop, syncTp1, syncTp2, syncTp3, syncLvlPx, syncLvlLbl, syncLvlRole] = f_parse_sync(ttSyncStr)

array<float> seedLvlPx = array.new_float()
array<string> seedLvlLbl = array.new_string()
array<string> seedLvlRole = array.new_string()
if seedOk
    if not na(seedLv1) and seedLv1 > 0
        array.push(seedLvlPx, seedLv1)
        array.push(seedLvlLbl, "L1")
        array.push(seedLvlRole, f_roleFromVol(seedRv1))
    if not na(seedLv2) and seedLv2 > 0
        array.push(seedLvlPx, seedLv2)
        array.push(seedLvlLbl, "L2")
        array.push(seedLvlRole, f_roleFromVol(seedRv2))
    if not na(seedLv3) and seedLv3 > 0
        array.push(seedLvlPx, seedLv3)
        array.push(seedLvlLbl, "L3")
        array.push(seedLvlRole, f_roleFromVol(seedRv3))
    if not na(seedLv4) and seedLv4 > 0
        array.push(seedLvlPx, seedLv4)
        array.push(seedLvlLbl, "L4")
        array.push(seedLvlRole, f_roleFromVol(seedRv4))
    if not na(seedLv5) and seedLv5 > 0
        array.push(seedLvlPx, seedLv5)
        array.push(seedLvlLbl, "L5")
        array.push(seedLvlRole, f_roleFromVol(seedRv5))
    if not na(seedLv6) and seedLv6 > 0
        array.push(seedLvlPx, seedLv6)
        array.push(seedLvlLbl, "L6")
        array.push(seedLvlRole, f_roleFromVol(seedRv6))
    if not na(seedLv7) and seedLv7 > 0
        array.push(seedLvlPx, seedLv7)
        array.push(seedLvlLbl, "L7")
        array.push(seedLvlRole, f_roleFromVol(seedRv7))
    if not na(seedLv8) and seedLv8 > 0
        array.push(seedLvlPx, seedLv8)
        array.push(seedLvlLbl, "L8")
        array.push(seedLvlRole, f_roleFromVol(seedRv8))

string activeMode = seedOk ? "GITHUB SEED" : useSync and syncOk ? "TT SYNC" : "LOCAL"
string inUniverse = seedOk ? (seedInU >= 0.5 ? "YES" : "NO") : useSync and syncOk ? syncUniv : "—"
string direction = seedOk ? f_dirFromCode(seedDirC) : useSync and syncOk ? syncDir : localDir
string bias = seedOk ? f_biasFromCode(seedBiasC) : useSync and syncOk ? syncBias : localBias
string stage = seedOk ? f_stageFromCode(seedStageC) : useSync and syncOk ? syncStage : "local"
string rankTxt = seedOk ? str.tostring(int(math.round(seedRank))) : useSync and syncOk ? syncRank : "—"
float stopPx = seedOk and not na(seedStop) and seedStop > 0 ? seedStop : useSync and syncOk and not na(syncStop) ? syncStop : localStop
float tp1Px = seedOk and not na(seedTp1) and seedTp1 > 0 ? seedTp1 : useSync and syncOk and not na(syncTp1) ? syncTp1 : localTp1
float tp2Px = useSync and syncOk and not na(syncTp2) ? syncTp2 : localTp2
float tp3Px = seedOk and not na(seedTpRun) and seedTpRun > 0 ? seedTpRun : useSync and syncOk and not na(syncTp3) ? syncTp3 : localTp3

// ─────────────────────────────────────────────────────────────────────────────
// Draw horizontal lines + labels (last bar only)
// ─────────────────────────────────────────────────────────────────────────────
var line lnStop = na
var line lnTp1 = na
var line lnTp2 = na
var line lnTp3 = na
var label lbStop = na
var label lbTp1 = na
var label lbTp2 = na
var label lbTp3 = na
var array<line> lvlLines = array.new_line()
var array<label> lvlLabels = array.new_label()

f_clear_lvl_drawings() =>
    while array.size(lvlLines) > 0
        line.delete(array.pop(lvlLines))
    while array.size(lvlLabels) > 0
        label.delete(array.pop(lvlLabels))

if barstate.islast
    if not na(lnStop)
        line.delete(lnStop)
    if not na(lnTp1)
        line.delete(lnTp1)
    if not na(lnTp2)
        line.delete(lnTp2)
    if not na(lnTp3)
        line.delete(lnTp3)
    if not na(lbStop)
        label.delete(lbStop)
    if not na(lbTp1)
        label.delete(lbTp1)
    if not na(lbTp2)
        label.delete(lbTp2)
    if not na(lbTp3)
        label.delete(lbTp3)
    f_clear_lvl_drawings()

    ext = extendLines ? extend.right : extend.none
    x1 = bar_index - 120
    x2 = bar_index + 12

    if showStop and not na(stopPx)
        lnStop := line.new(x1, stopPx, x2, stopPx, color=color.new(color.red, 0), width=2, style=line.style_solid, extend=ext)
        lbStop := label.new(x2, stopPx, "STOP " + str.tostring(stopPx, format.mintick), style=label.style_label_left, color=color.new(color.red, 15), textcolor=color.white, size=size.small)

    if showTargets and not na(tp1Px)
        lnTp1 := line.new(x1, tp1Px, x2, tp1Px, color=color.new(color.lime, 0), width=2, style=line.style_dashed, extend=ext)
        lbTp1 := label.new(x2, tp1Px, "TRIM " + str.tostring(tp1Px, format.mintick), style=label.style_label_left, color=color.new(color.lime, 20), textcolor=color.white, size=size.small)
    if showTargets and not na(tp2Px)
        lnTp2 := line.new(x1, tp2Px, x2, tp2Px, color=color.new(color.green, 10), width=2, style=line.style_dashed, extend=ext)
        lbTp2 := label.new(x2, tp2Px, "EXIT " + str.tostring(tp2Px, format.mintick), style=label.style_label_left, color=color.new(color.green, 25), textcolor=color.white, size=size.small)
    if showTargets and not na(tp3Px)
        lnTp3 := line.new(x1, tp3Px, x2, tp3Px, color=color.new(color.teal, 25), width=1, style=line.style_dotted, extend=ext)
        lbTp3 := label.new(x2, tp3Px, "RUNNER " + str.tostring(tp3Px, format.mintick), style=label.style_label_left, color=color.new(color.teal, 30), textcolor=color.white, size=size.tiny)

    if showLevels
        if seedOk and array.size(seedLvlPx) > 0
            for i = 0 to array.size(seedLvlPx) - 1
                px = array.get(seedLvlPx, i)
                lbl = array.get(seedLvlLbl, i)
                role = array.get(seedLvlRole, i)
                col = f_roleColor(role)
                ln = line.new(x1, px, x2, px, color=col, width=1, style=line.style_dotted, extend=ext)
                lb = label.new(x2, px, lbl + " " + str.tostring(px, format.mintick), style=label.style_label_left, color=color.new(col, 70), textcolor=color.white, size=size.tiny)
                array.push(lvlLines, ln)
                array.push(lvlLabels, lb)
        else if useSync and syncOk and array.size(syncLvlPx) > 0
            for i = 0 to array.size(syncLvlPx) - 1
                px = array.get(syncLvlPx, i)
                lbl = array.get(syncLvlLbl, i)
                role = array.get(syncLvlRole, i)
                col = f_roleColor(role)
                ln = line.new(x1, px, x2, px, color=col, width=1, style=line.style_dotted, extend=ext)
                lb = label.new(x2, px, lbl + " " + str.tostring(px, format.mintick), style=label.style_label_left, color=color.new(col, 70), textcolor=color.white, size=size.tiny)
                array.push(lvlLines, ln)
                array.push(lvlLabels, lb)
        else if (not useSeed or not seedOk) and (not useSync or not syncOk)
            if not na(swingLo)
                px = swingLo
                ln = line.new(x1, px, x2, px, color=color.new(color.teal, 40), width=1, style=line.style_dotted, extend=ext)
                lb = label.new(x2, px, "Swing Support " + str.tostring(px, format.mintick), style=label.style_label_left, color=color.new(color.teal, 75), textcolor=color.white, size=size.tiny)
                array.push(lvlLines, ln)
                array.push(lvlLabels, lb)
            if not na(swingHi)
                px = swingHi
                ln = line.new(x1, px, x2, px, color=color.new(color.orange, 40), width=1, style=line.style_dotted, extend=ext)
                lb = label.new(x2, px, "Swing Resistance " + str.tostring(px, format.mintick), style=label.style_label_left, color=color.new(color.orange, 75), textcolor=color.white, size=size.tiny)
                array.push(lvlLines, ln)
                array.push(lvlLabels, lb)

// ─────────────────────────────────────────────────────────────────────────────
// Bias table
// ─────────────────────────────────────────────────────────────────────────────
var table hud = table.new(position.top_right, 2, 8, border_width=1)
if showTable and barstate.islast
    hdrBg = color.new(color.black, 0)
    dirCol = f_dirColor(direction)
    table.cell(hud, 0, 0, "Timed Trading", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 0, activeMode, text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 0, 1, "TT Universe", text_color=color.white, bgcolor=hdrBg)
    univCol = inUniverse == "YES" ? color.new(color.teal, 50) : inUniverse == "NO" ? color.new(color.red, 50) : color.new(color.gray, 60)
    table.cell(hud, 1, 1, inUniverse, text_color=color.white, bgcolor=univCol)
    table.cell(hud, 0, 2, "Direction", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 2, direction, text_color=color.white, bgcolor=color.new(dirCol, 55))
    table.cell(hud, 0, 3, "Bias", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 3, bias, text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 0, 4, "Stage", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 4, stage, text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 0, 5, "Rank", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 5, rankTxt, text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 0, 6, "Stop", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 1, 6, not na(stopPx) ? str.tostring(stopPx, format.mintick) : "—", text_color=color.white, bgcolor=hdrBg)
    table.cell(hud, 0, 7, "Targets", text_color=color.white, bgcolor=hdrBg)
    tgtTxt = (not na(tp1Px) ? "T1 " + str.tostring(tp1Px, format.mintick) : "—")
    tgtTxt += not na(tp2Px) ? " · T2 " + str.tostring(tp2Px, format.mintick) : ""
    tgtTxt += not na(tp3Px) ? " · T3 " + str.tostring(tp3Px, format.mintick) : ""
    table.cell(hud, 1, 7, tgtTxt, text_color=color.white, bgcolor=hdrBg)

// Subtle direction tint
bgcolor(direction == "LONG" ? color.new(color.teal, 96) : direction == "SHORT" ? color.new(color.red, 96) : na)

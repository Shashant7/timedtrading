if barstate.islast and show_atr_levels
    // Upper core - Tags (on chart)
    t_u100  := f_tag_upd(t_u100,  tags_show_u100,  upper_1000, "+100%", f_is_near_level(upper_1000, proximity_threshold))
    t_u786  := f_tag_upd(t_u786,  tags_show_u786 and show_all_fibonacci_levels, upper_0786, "78.6%", f_is_near_level(upper_0786, proximity_threshold))
    t_u618  := f_tag_upd(t_u618,  tags_show_u618,  upper_0618, "61.8%", f_is_near_level(upper_0618, proximity_threshold))
    t_u500  := f_tag_upd(t_u500,  tags_show_u500 and show_all_fibonacci_levels, upper_0500, "50%", f_is_near_level(upper_0500, proximity_threshold))
    t_u382  := f_tag_upd(t_u382,  tags_show_u382 and show_all_fibonacci_levels, upper_0382, "38.2%", f_is_near_level(upper_0382, proximity_threshold))
    t_utrig := f_tag_upd(t_utrig, tags_show_utrig, upper_trigger, "Upper Trig", f_is_near_level(upper_trigger, proximity_threshold))
    t_pc    := f_tag_upd(t_pc,    tags_show_pc,    prev_close, "Prev Close", f_is_near_level(prev_close, proximity_threshold))

    // Upper extensions - Tags
    t_u1236 := f_tag_upd(t_u1236, tags_show_u1236 and show_extensions, upper_1236, "123.6%", f_is_near_level(upper_1236, proximity_threshold))
    t_u1382 := f_tag_upd(t_u1382, tags_show_u1382 and show_all_fibonacci_levels and show_extensions, upper_1382, "138.2%", f_is_near_level(upper_1382, proximity_threshold))
    t_u1500 := f_tag_upd(t_u1500, tags_show_u1500 and show_all_fibonacci_levels and show_extensions, upper_1500, "150.0%", f_is_near_level(upper_1500, proximity_threshold))
    t_u1618 := f_tag_upd(t_u1618, tags_show_u1618 and show_extensions, upper_1618, "161.8%", f_is_near_level(upper_1618, proximity_threshold))
    t_u1786 := f_tag_upd(t_u1786, tags_show_u1786 and show_all_fibonacci_levels and show_extensions, upper_1786, "178.6%", f_is_near_level(upper_1786, proximity_threshold))
    t_u200  := f_tag_upd(t_u200,  tags_show_u200  and show_extensions, upper_2000, "+200%", f_is_near_level(upper_2000, proximity_threshold))
    t_u2236 := f_tag_upd(t_u2236, tags_show_u2236 and show_extensions, upper_2236, "223.6%", f_is_near_level(upper_2236, proximity_threshold))
    t_u2618 := f_tag_upd(t_u2618, tags_show_u2618 and show_extensions, upper_2618, "261.8%", f_is_near_level(upper_2618, proximity_threshold))
    t_u300  := f_tag_upd(t_u300,  tags_show_u300  and show_extensions, upper_3000, "+300%", f_is_near_level(upper_3000, proximity_threshold))

    // Lower core - Tags
    t_l100  := f_tag_upd(t_l100,  tags_show_l100,  lower_1000, "-100%", f_is_near_level(lower_1000, proximity_threshold))
    t_l786  := f_tag_upd(t_l786,  tags_show_l786 and show_all_fibonacci_levels, lower_0786, "-78.6%", f_is_near_level(lower_0786, proximity_threshold))
    t_l618  := f_tag_upd(t_l618,  tags_show_l618,  lower_0618, "-61.8%", f_is_near_level(lower_0618, proximity_threshold))
    t_l500  := f_tag_upd(t_l500,  tags_show_l500 and show_all_fibonacci_levels, lower_0500, "-50%", f_is_near_level(lower_0500, proximity_threshold))
    t_l382  := f_tag_upd(t_l382,  tags_show_l382 and show_all_fibonacci_levels, lower_0382, "-38.2%", f_is_near_level(lower_0382, proximity_threshold))
    t_ltrig := f_tag_upd(t_ltrig, tags_show_ltrig, lower_trigger, "Lower Trig", f_is_near_level(lower_trigger, proximity_threshold))

    // Lower extensions - Tags
    t_l1236 := f_tag_upd(t_l1236, tags_show_l1236 and show_extensions, lower_1236, "-123.6%", f_is_near_level(lower_1236, proximity_threshold))
    t_l1382 := f_tag_upd(t_l1382, tags_show_l1382 and show_all_fibonacci_levels and show_extensions, lower_1382, "-138.2%", f_is_near_level(lower_1382, proximity_threshold))
    t_l1500 := f_tag_upd(t_l1500, tags_show_l1500 and show_all_fibonacci_levels and show_extensions, lower_1500, "-150.0%", f_is_near_level(lower_1500, proximity_threshold))
    t_l1618 := f_tag_upd(t_l1618, tags_show_l1618 and show_extensions, lower_1618, "-161.8%", f_is_near_level(lower_1618, proximity_threshold))
    t_l1786 := f_tag_upd(t_l1786, tags_show_l1786 and show_all_fibonacci_levels and show_extensions, lower_1786, "-178.6%", f_is_near_level(lower_1786, proximity_threshold))
    t_l200  := f_tag_upd(t_l200,  tags_show_l200  and show_extensions, lower_2000, "-200%", f_is_near_level(lower_2000, proximity_threshold))
    t_l2236 := f_tag_upd(t_l2236, tags_show_l2236 and show_extensions, lower_2236, "-223.6%", f_is_near_level(lower_2236, proximity_threshold))
    t_l2618 := f_tag_upd(t_l2618, tags_show_l2618 and show_extensions, lower_2618, "-261.8%", f_is_near_level(lower_2618, proximity_threshold))
    t_l300  := f_tag_upd(t_l300,  tags_show_l300  and show_extensions, lower_3000, "-300%", f_is_near_level(lower_3000, proximity_threshold))
// ──────────────────────────────────────────────────────────────
// MTF SuperTrend Visuals (1m / 3m / 10m)
// ──────────────────────────────────────────────────────────────

// Helper to fetch ST line + direction on a given TF
f_mtf_st_pair(string tf, float factor, int atrLen) =>
    request.security(
         syminfo.tickerid,
         tf,
         array.from(f_supertrend_val(factor, atrLen, 0), f_supertrend_val(factor, atrLen, 1)),
         barmerge.gaps_off,
         barmerge.lookahead_off)

// 1m SuperTrend (values)
float st1_line = na
float st1_dir  = na
if mtfST_1m_show
    float[] _st1 = f_mtf_st_pair("1", mtfST_1m_factor, mtfST_1m_atr_len)
    st1_line := array.get(_st1, 0)
    st1_dir  := array.get(_st1, 1)
st1_line := barstate.isfirst ? na : st1_line

st1_up   = plot(
     mtfST_1m_show and st1_dir < 0  ? st1_line : na,
     title = "ST 1m Up Trend",
     color = mtfST_1m_up_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale)


st1_down = plot(
     mtfST_1m_show and st1_dir >= 0 ? st1_line : na,
     title = "ST 1m Down Trend",
     color = mtfST_1m_dn_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale)


// 3m SuperTrend (values)
float st3_line = na
float st3_dir  = na
if mtfST_3m_show
    float[] _st3 = f_mtf_st_pair("3", mtfST_3m_factor, mtfST_3m_atr_len)
    st3_line := array.get(_st3, 0)
    st3_dir  := array.get(_st3, 1)
st3_line := barstate.isfirst ? na : st3_line

st3_up   = plot(
     mtfST_3m_show and st3_dir < 0  ? st3_line : na,
     title = "ST 3m Up Trend",
     color = mtfST_3m_up_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale)


st3_down = plot(
     mtfST_3m_show and st3_dir >= 0 ? st3_line : na,
     title = "ST 3m Down Trend",
     color = mtfST_3m_dn_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale)


// 10m SuperTrend (values)
float st10_line = na
float st10_dir  = na
if mtfST_10m_show
    float[] _st10 = f_mtf_st_pair("10", mtfST_10m_factor, mtfST_10m_atr_len)
    st10_line := array.get(_st10, 0)
    st10_dir  := array.get(_st10, 1)
st10_line := barstate.isfirst ? na : st10_line

st10_up   = plot(
     mtfST_10m_show and st10_dir < 0  ? st10_line : na,
     title = "ST 10m Up Trend",
     color = mtfST_10m_up_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale) 

st10_down = plot(
     mtfST_10m_show and st10_dir >= 0 ? st10_line : na,
     title = "ST 10m Down Trend",
     color = mtfST_10m_dn_color,
     style = plot.style_linebr,
     linewidth = 2,
     display=display.all - display.price_scale)


// 30m SuperTrend (values) - commented out to reduce plot count
// float st30_line = na
// float st30_dir  = na
// if mtfST_30m_show
//     float[] _st30 = f_mtf_st_pair("30", mtfST_30m_factor, mtfST_30m_atr_len)
//     st30_line := array.get(_st30, 0)
//     st30_dir  := array.get(_st30, 1)
// st30_line := barstate.isfirst ? na : st30_line

// st30_up   = plot(
//      mtfST_30m_show and st30_dir < 0  ? st30_line : na,
//      title = "ST 30m Up Trend",
//      color = mtfST_30m_up_color,
//      style = plot.style_linebr,
//      linewidth = 2,
//      display=display.all - display.price_scale)

// st30_down = plot(     mtfST_30m_show and st30_dir >= 0 ? st30_line : na,     title = "ST 30m Down Trend",     color = mtfST_30m_dn_color,     style = plot.style_linebr,     linewidth = 2,     display=display.all - display.price_scale)


// ──────────────────────────────────────────────────────────────
// I) Golden Gate classic + one-time RTH visuals
// ──────────────────────────────────────────────────────────────
openUpSignal = gg_open_mode=="Cross 38.2" ? ta.crossover(high, upper_0382) : (high >= upper_0382)
openDnSignal = gg_open_mode=="Cross 38.2" ? ta.crossunder(low,  lower_0382) : (low  <= lower_0382)
closeUpSignal = gg_close_mode=="Cross 61.8" ? ta.crossover(high, upper_0618) : (high >= upper_0618)
closeDnSignal = gg_close_mode=="Cross 61.8" ? ta.crossunder(low,  lower_0618) : (low  <= lower_0618)

// Gate (one per side per anchor period)
anchorTime  = request.security(syminfo.tickerid, anchor_tf, time, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
newPeriod   = ta.change(anchorTime) != 0
var bool upOpenedThisPeriod=false, dnOpenedThisPeriod=false
if newPeriod
    upOpenedThisPeriod:=false
    dnOpenedThisPeriod:=false

canOpenUp = gg_enable and openUpSignal and (not upOpenedThisPeriod)
canOpenDn = gg_enable and openDnSignal and (not dnOpenedThisPeriod)

// Daily gating for GG visuals (once per direction per day)
// Use the start-time of the daily bar as a "day key" (same for all bars in that calendar day)
var int gg_lastOpenUpDay   = na
var int gg_lastOpenDnDay   = na
var int gg_lastCloseUpDay  = na
var int gg_lastCloseDnDay  = na

int gg_curDay = int(time("D"))  // daily-session key; changes once per calendar day

// RTH-only GG visuals — once per direction per *day*
var bool rth_open_plotted_up=false, rth_open_plotted_dn=false
var bool rth_close_plotted_up=false, rth_close_plotted_dn=false

if rthStart()
    rth_open_plotted_up  := false
    rth_open_plotted_dn  := false
    rth_close_plotted_up := false
    rth_close_plotted_dn := false

// Raw RTH conditions (per-session) — pure cross semantics
bool rawOpenUp  = inRTH() and openUpSignal
bool rawOpenDn  = inRTH() and openDnSignal
bool rawCloseUp = inRTH() and closeUpSignal
bool rawCloseDn = inRTH() and closeDnSignal

// Daily gating (once per direction per calendar day)
showOpenUp  = rawOpenUp  and (na(gg_lastOpenUpDay)  or gg_lastOpenUpDay  != gg_curDay)
showOpenDn  = rawOpenDn  and (na(gg_lastOpenDnDay)  or gg_lastOpenDnDay  != gg_curDay)
showCloseUp = rawCloseUp and (na(gg_lastCloseUpDay) or gg_lastCloseUpDay != gg_curDay)
showCloseDn = rawCloseDn and (na(gg_lastCloseDnDay) or gg_lastCloseDnDay != gg_curDay)

// GG label Y-levels (offset from bar highs/lows)
float ggUpY  = high + fromTicks(ggOpen_offsetTicks)
float ggDnY  = low  - fromTicks(ggOpen_offsetTicks)

// GG Open markers (🚧, black background) — offset by gg_emoji_offset_ticks
// GG Open markers (🚧, black background) — offset by gg_emoji_offset_ticks
if showOpenUp
    f_push_lbl(label.new(
         bar_index, ggUpY, "🚧",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_down,
         size  = ggOpen_size,
         textcolor = color.white,
         color     = color.new(color.white, 90)))

if showOpenDn
    f_push_lbl(label.new(
         bar_index, ggDnY, "🚧",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_up,
         size  = ggOpen_size,
         textcolor = color.white,
         color     = color.new(color.white, 90)))


// GG Close markers (also 🚧 + black background, with text)
if showCloseUp
    f_push_lbl(label.new(
         bar_index, ggUpY, "🚪",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_down,
         size  = ggClose_size,
         textcolor = color.white,
         color     = color.new(color.white, 90)))

if showCloseDn
    f_push_lbl(label.new(
         bar_index, ggDnY, "🚪",
         xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_up,
         size  = ggClose_size,
         textcolor = color.white,
         color     = color.new(color.white, 90)))

// Update “seen today” registry
if showOpenUp
    gg_lastOpenUpDay := gg_curDay
if showOpenDn
    gg_lastOpenDnDay := gg_curDay
if showCloseUp
    gg_lastCloseUpDay := gg_curDay
if showCloseDn
    gg_lastCloseDnDay := gg_curDay
// ──────────────────────────────────────────────────────────────
// J) Scan alerts (Daily / Weekly / Monthly / Quarterly)
// ──────────────────────────────────────────────────────────────

// Base scan signals on this chart's TF vs ±38.2 levels
openUpSignalScan = ta.crossover(high, upper_0382)
openDnSignalScan = ta.crossunder(low,  lower_0382)

// Timeframe helpers (based on your auto trading mode)
is30m = timeframe.isminutes and timeframe.multiplier == 30
is1h  = timeframe.isminutes and timeframe.multiplier == 60
is4h  = timeframe.isminutes and timeframe.multiplier == 240

isDay      = f_resolve_trading_type() == day_trading
isMultiday = f_resolve_trading_type() == multiday_trading
isSwing    = f_resolve_trading_type() == swing_trading
isPosition = f_resolve_trading_type() == position_trading

// DAILY scan: intraday <= 15m, anchored to D (day_trading → anchor_tf = "D")
isDailyScan       = timeframe.isminutes and timeframe.multiplier <= 15 and isDay
gg_open_up_daily  = isDailyScan and openUpSignalScan
gg_open_dn_daily  = isDailyScan and openDnSignalScan

// WEEKLY scan: 30m + Multiday (anchor_tf = "W")
gg_open_up_weekly = is30m and isMultiday and openUpSignalScan
gg_open_dn_weekly = is30m and isMultiday and openDnSignalScan

// MONTHLY scan: 1h + Swing (anchor_tf = "M")
gg_open_up_monthly = is1h and isSwing and openUpSignalScan
gg_open_dn_monthly = is1h and isSwing and openDnSignalScan

// QUARTERLY scan: 4h + Position (anchor_tf = "3M")
gg_open_up_quarter = is4h and isPosition and openUpSignalScan
gg_open_dn_quarter = is4h and isPosition and openDnSignalScan

// ── Per-frame / per-direction alertconditions with CONST messages ──

// DAILY (anchor D)
alertcondition(     gg_open_up_daily,     title   = "GG OPEN Daily UP",     message = "GG OPEN Daily UP | {{ticker}} | Anchor=D | Crossed +38.2% upper ATR band")

alertcondition(     gg_open_dn_daily,     title   = "GG OPEN Daily DOWN",     message = "GG OPEN Daily DOWN | {{ticker}} | Anchor=D | Crossed -38.2% lower ATR band")

// WEEKLY (anchor W)
alertcondition(     gg_open_up_weekly,     title   = "GG OPEN Weekly UP",     message = "GG OPEN Weekly UP | {{ticker}} | Anchor=W | Crossed +38.2% upper ATR band")

alertcondition(     gg_open_dn_weekly,     title   = "GG OPEN Weekly DOWN",     message = "GG OPEN Weekly DOWN | {{ticker}} | Anchor=W | Crossed -38.2% lower ATR band")

// MONTHLY (anchor M)
alertcondition(     gg_open_up_monthly,     title   = "GG OPEN Monthly UP",     message = "GG OPEN Monthly UP | {{ticker}} | Anchor=M | Crossed +38.2% upper ATR band")

alertcondition(     gg_open_dn_monthly,     title   = "GG OPEN Monthly DOWN",     message = "GG OPEN Monthly DOWN | {{ticker}} | Anchor=M | Crossed -38.2% lower ATR band")

// QUARTERLY (anchor 3M)
alertcondition(     gg_open_up_quarter,     title   = "GG OPEN Quarterly UP",     message = "GG OPEN Quarterly UP | {{ticker}} | Anchor=3M | Crossed +38.2% upper ATR band")

alertcondition(     gg_open_dn_quarter,     title   = "GG OPEN Quarterly DOWN",     message = "GG OPEN Quarterly DOWN | {{ticker}} | Anchor=3M | Crossed -38.2% lower ATR band")
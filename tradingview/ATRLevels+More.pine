// Effective feature toggles (after inputs are defined)
show_extensions = (mobileMode and extDisableOnMobile) ? false : show_extensions_input
tags_enable     = (mobileMode and tagsDisableOnMobile) ? false : tags_enable_input


// Rolling label buffer for any label.new() that can accumulate
var label[] _eventLbls = array.new_label()

f_push_lbl(label l) =>
    if maxEventLabels <= 0
        label.delete(l)
    else
        array.push(_eventLbls, l)
        if array.size(_eventLbls) > maxEventLabels
            label.delete(array.shift(_eventLbls))

// Helper: “leaving” flags for a given PO series
f_po_leave_flags(series float po) =>
    bool leave_acc  = po[1] <= -61.8 and po > -61.8
    bool leave_dn   = po[1] <= -100  and po > -100
    bool leave_dist = po[1] >=  61.8 and po <  61.8
    bool leave_up   = po[1] >=  100  and po <  100
    [leave_acc, leave_dn, leave_dist, leave_up]

toTicks(x)=>x/syminfo.mintick
fromTicks(n)=>n*syminfo.mintick

// Helper: detect if instrument is a stock
// Futures typically have "!" in the ticker symbol, so if it doesn't have "!", assume it's a stock
f_is_stock() =>
    not str.contains(syminfo.ticker, "!")

// Helper: get dynamic threshold based on instrument type
// Futures: 12 ticks
// Stocks: points based on price (1 pt if < $1000, up to 5 pts if >= $1000), capped at 0.5% of close
f_get_proximity_threshold() =>
    if f_is_stock()
        // For stocks: use points based on price, but cap at 0.5% of close
        float points_threshold = close >= 1000.0 ? 5.0 : 1.0
        float points_ticks = points_threshold / syminfo.mintick
        float percent_ticks = (close * 0.005) / syminfo.mintick
        // Use the minimum to ensure 0.5% is the maximum cap
        float threshold_ticks_float = math.min(math.max(points_ticks, 100.0), percent_ticks)
        int(threshold_ticks_float)
    else
        // For futures: 12 ticks
        12

// Helper: check if price is within threshold of a level (dynamic based on instrument type)
f_is_near_level(float level, int tickThreshold) =>
    if na(level)
        false
    else
        float tickDist = math.abs(close - level) / syminfo.mintick
        tickDist <= tickThreshold

// Map size option string → label size enum
lbl_size(string opt) =>
    opt == "tiny"   ? size.tiny  :    opt == "small"  ? size.small :    opt == "normal" ? size.normal:    opt == "large"  ? size.large :                      size.huge

// Helper to bump one step (optional, used if you want later)
f_bump_size(string opt) =>
    opt == "tiny"   ? "small"  :    opt == "small"  ? "normal" :    opt == "normal" ? "large"  :    opt == "large"  ? "huge"   : "huge"

// Concrete size enums used later in the script
emaX_size   = lbl_size(emaX_sizeOpt)
rsiDiv_size = lbl_size(rsiDiv_sizeOpt)
rsiExt_size = lbl_size(rsiExt_sizeOpt)
poDiv_size  = lbl_size(poDiv_sizeOpt)
ggOpen_size = lbl_size(ggOpen_sizeOpt)
ggClose_size= lbl_size(ggClose_sizeOpt)

f_clamp(float x, float lo, float hi) =>
    math.min(math.max(x, lo), hi)

// Divergence helpers (separate state for RSI and PO)
f_div_emoji_rsi(series float osc, int pivotLen) =>
    var float pl1_price = na
    var float pl2_price = na
    var float pl1_osc   = na
    var float pl2_osc   = na
    var int   pl1_bar   = na
    var int pl2_bar   = na

    var float ph1_price = na
    var float ph2_price = na
    var float ph1_osc   = na
    var float ph2_osc   = na
    var int   ph1_bar   = na
    var int ph2_bar   = na

    var string lastSig_rsi  = ""

    string sig = lastSig_rsi

    float newPL = ta.pivotlow(low, pivotLen, pivotLen)
    if not na(newPL)
        pl2_price := pl1_price
        pl2_osc   := pl1_osc
        pl2_bar   := pl1_bar

        pl1_price := newPL
        pl1_osc   := osc[pivotLen]
        pl1_bar   := bar_index - pivotLen

        bool bull = not na(pl2_price) and not na(pl2_osc) and pl1_price < pl2_price and pl1_osc > pl2_osc
        if bull
            sig := "🐂"

    float newPH = ta.pivothigh(high, pivotLen, pivotLen)
    if not na(newPH)
        ph2_price := ph1_price
        ph2_osc   := ph1_osc
        ph2_bar   := ph1_bar

        ph1_price := newPH
        ph1_osc   := osc[pivotLen]
        ph1_bar   := bar_index - pivotLen

        bool bear = not na(ph2_price) and not na(ph2_osc) and ph1_price > ph2_price and ph1_osc < ph2_osc
        if bear
            sig := "🐻"

    lastSig_rsi := sig
    sig

f_div_emoji_rsi_slow(series float osc, int pivotLen) =>
    var float pl1_price_s = na
    var float pl2_price_s = na
    var float pl1_osc_s   = na
    var float pl2_osc_s   = na
    var int   pl1_bar_s   = na
    var int   pl2_bar_s   = na

    var float ph1_price_s = na
    var float ph2_price_s = na
    var float ph1_osc_s   = na
    var float ph2_osc_s   = na
    var int   ph1_bar_s   = na
    var int   ph2_bar_s   = na

    var string lastSig_rsi_s  = ""
    string sig = lastSig_rsi_s

    float newPLs = ta.pivotlow(low, pivotLen, pivotLen)
    if not na(newPLs)
        pl2_price_s := pl1_price_s
        pl2_osc_s   := pl1_osc_s
        pl2_bar_s   := pl1_bar_s

        pl1_price_s := newPLs
        pl1_osc_s   := osc[pivotLen]
        pl1_bar_s   := bar_index - pivotLen

        bool bulls = not na(pl2_price_s) and not na(pl2_osc_s) and pl1_price_s < pl2_price_s and pl1_osc_s > pl2_osc_s
        if bulls
            sig := "🐂"

    float newPHs = ta.pivothigh(high, pivotLen, pivotLen)
    if not na(newPHs)
        ph2_price_s := ph1_price_s
        ph2_osc_s   := ph1_osc_s
        ph2_bar_s   := ph1_bar_s

        ph1_price_s := newPHs
        ph1_osc_s   := osc[pivotLen]
        ph1_bar_s   := bar_index - pivotLen

        bool bears = not na(ph2_price_s) and not na(ph2_osc_s) and ph1_price_s > ph2_price_s and ph1_osc_s < ph2_osc_s
        if bears
            sig := "🐻"

    lastSig_rsi_s := sig
    sig

f_resolve_trading_type() =>
    if not auto_mode
        trading_type_manual
    else
        secs=nz(timeframe.in_seconds(timeframe.period),60)
        if timeframe.isintraday
            secs<30*60?day_trading:secs<60*60?multiday_trading:secs<240*60?swing_trading:position_trading
        else if timeframe.isdaily
            position_trading
        else if timeframe.isweekly
            swing_trading
        else if timeframe.ismonthly
            longterm_trading
        else
            position_trading

f_anchor_tf(tt)=>
    tt==day_trading?"D":tt==multiday_trading?"W":tt==swing_trading?"M":tt==position_trading?"3M":"12M"

// Core Saty compression test on the *current* TF (reusable)
_saty_compressed_chart() =>
    _p = ta.ema(close, 21)
    _a = ta.atr(14)
    _bbo = 2.0 * ta.stdev(close, 21)
    _bup = _p + _bbo
    _bdn = _p - _bbo
    _ctUp = _p + 2.0 * _a
    _ctDn = _p - 2.0 * _a
    _exUp = _p + 1.854 * _a
    _exDn = _p - 1.854 * _a
    _above = close >= _p
    _compression = _above ? (_bup - _ctUp) : (_ctDn - _bdn)
    _inExp = _above ? (_bup - _exUp) : (_exDn - _bdn)
    _expanding = nz(_compression[1]) <= _compression
    not (_expanding and _inExp > 0) and _compression <= 0

// ──────────────────────────────────────────────────────────────
// Compression flag (Chart TF) — define ONCE, used everywhere
// ──────────────────────────────────────────────────────────────
bool isCompressed_chart = _saty_compressed_chart()

// Exact Saty Phase Oscillator formula (v5 logic, ported to v6)
po_pivot = ta.ema(close, 21)
po_atr   = ta.atr(14)
po_raw   = ((close - po_pivot) / (3.0 * po_atr)) * 100.0
saty_po  = ta.ema(po_raw, 3)

// ──────────────────────────────────────────────────────────────
// Directional Compression Candle Tint (native candles)
// ──────────────────────────────────────────────────────────────
bool isUpBar = close >= open

color compBarColor =
     compTint_enable and showCompTint and isCompressed_chart
     ? (isUpBar ? compTint_up_color : compTint_down_color)
     : na

barcolor(compBarColor)

// Saty Phase Oscillator on an arbitrary timeframe (tf like "1", "10", "5", etc.)
f_saty_po_tf(string tf) =>
    request.security(
         syminfo.tickerid,
         tf,
         ta.ema(
             ((close - ta.ema(close, 21)) / (3.0 * ta.atr(14))) * 100.0,
             3),
         gaps      = barmerge.gaps_off,
         lookahead = barmerge.lookahead_off)

// Saty compression flag on an arbitrary timeframe using the same logic as _saty_compressed_chart
f_saty_compressed_tf(string tf) =>
    request.security(
         syminfo.tickerid,
         tf,
         _saty_compressed_chart(),
         gaps      = barmerge.gaps_off,
         lookahead = barmerge.lookahead_off)

inRTH()=>not na(time(timeframe.period, rth_sess, rth_tz))
rthStart()=>inRTH() and not inRTH()[1]

// SuperTrend core (used for MTF ST)
// mode = 0 → return supertrend line, mode = 1 → return direction (+1 / -1)
f_supertrend_val(float factor, int atrPeriod, int mode) =>
    float _atr  = ta.atr(atrPeriod)
    float _hl2  = (high + low) / 2.0
    float _up   = _hl2 + factor * _atr
    float _dn   = _hl2 - factor * _atr

    var float _fUp = na
    var float _fDn = na
    var int   _dir = na

    _fUp := na(_fUp[1]) ? _up :        (_up < _fUp[1] or close[1] > _fUp[1] ? _up : _fUp[1])

    _fDn := na(_fDn[1]) ? _dn :        (_dn > _fDn[1] or close[1] < _fDn[1] ? _dn : _fDn[1])

    _dir := na(_dir[1]) ? 1 :        _dir[1] == -1 and close > _fUp[1] ? 1 :        _dir[1] ==  1 and close < _fDn[1] ? -1 :        _dir[1]

    float _st = _dir == 1 ? _fDn : _fUp
    mode == 0 ? _st : _dir

// Trend color (unchanged look)
price=close
fEMA=ta.ema(price,fast_ema)
pEMA=ta.ema(price,pivot_ema)
sEMA=ta.ema(price,slow_ema)
bullish=price>=fEMA and fEMA>=pEMA and pEMA>=sEMA
bearish=price<=fEMA and fEMA<=pEMA and pEMA<=sEMA
trend_color=bullish?color.green:bearish?color.red:color.orange

// ──────────────────────────────────────────────────────────────
// 🏴‍☠️ Fast EMA crosses Slow EMA
// ──────────────────────────────────────────────────────────────


// Cross conditions
bool emaX_up = ta.crossover(fEMA, sEMA)
bool emaX_dn = ta.crossunder(fEMA, sEMA)

// Y positions (above bar for up-cross, below bar for down-cross)
float emaX_y_up = high + fromTicks(emaX_offsetTicks)
float emaX_y_dn = low  - fromTicks(emaX_offsetTicks)

if emaX_enable and emaX_up
    f_push_lbl(label.new(
         bar_index, emaX_y_up, "🏴‍☠️",
         xloc=xloc.bar_index, yloc=yloc.price,
         style=label.style_label_down,
         size=emaX_size,
         textcolor=emaX_textColor,
         color=emaX_bgColor))

if emaX_enable and emaX_dn
    f_push_lbl(label.new(
         bar_index, emaX_y_dn, "🏴‍☠️",
         xloc=xloc.bar_index, yloc=yloc.price,
         style=label.style_label_up,
         size=emaX_size,
         textcolor=emaX_textColor,
         color=emaX_bgColor))
// ──────────────────────────────────────────────────────────────
// C) Anchor TF + ATR levels (same math as v1.5)
// ──────────────────────────────────────────────────────────────
trading_type=f_resolve_trading_type()
anchor_tf=f_anchor_tf(trading_type)

// Use extended session for anchor TF, just like Saty's v5
var string anchorTicker = ticker.new(syminfo.prefix, syminfo.ticker, session = session.extended)

period_index = use_current_close ? 0 : 1
prev_close   = request.security(anchorTicker, anchor_tf, close[period_index], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
atr_val      = request.security(anchorTicker, anchor_tf, ta.atr(atr_length)[period_index], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
per_high     = request.security(anchorTicker, anchor_tf, high, gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
per_low      = request.security(anchorTicker, anchor_tf, low,  gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

lower_trigger=prev_close-trigger_percentage*atr_val
upper_trigger=prev_close+trigger_percentage*atr_val

// Core levels (keep as plots)
lower_0382=prev_close-atr_val*0.382, upper_0382=prev_close+atr_val*0.382
lower_0500=prev_close-atr_val*0.5,   upper_0500=prev_close+atr_val*0.5
lower_0618=prev_close-atr_val*0.618, upper_0618=prev_close+atr_val*0.618
lower_0786=prev_close-atr_val*0.786, upper_0786=prev_close+atr_val*0.786
lower_1000=prev_close-atr_val,       upper_1000=prev_close+atr_val

// Extensions (drawn as line objects, not plots)
lower_1236=lower_1000-atr_val*0.236, upper_1236=upper_1000+atr_val*0.236
lower_1382=lower_1000-atr_val*0.382, upper_1382=upper_1000+atr_val*0.382
lower_1500=lower_1000-atr_val*0.5,   upper_1500=upper_1000+atr_val*0.5
lower_1618=lower_1000-atr_val*0.618, upper_1618=upper_1000+atr_val*0.618
lower_1786=lower_1000-atr_val*0.786, upper_1786=upper_1000+atr_val*0.786
lower_2000=lower_1000-atr_val,       upper_2000=upper_1000+atr_val
lower_2236=lower_2000-atr_val*0.236, upper_2236=upper_2000+atr_val*0.236
lower_2618=lower_2000-atr_val*0.618, upper_2618=upper_2000+atr_val*0.618
lower_3000=lower_2000-atr_val,       upper_3000=upper_2000+atr_val

// ──────────────────────────────────────────────────────────────
// Price Scale Labels (LEAN set, color-matched) — saves plot budget
// ──────────────────────────────────────────────────────────────
group_ps  = "Price Scale Labels"
ps_enable = input.bool(true, "Show Levels on Price Scale (Lean)", group=group_ps)

// gates
bool ps_on  = ps_enable and show_atr_levels
bool ps_ext = ps_on and show_extensions  // respects mobileMode/extDisableOnMobile via show_extensions

// colors (match your ATR palette)
color c_pc    = color.new(previous_close_level_color, 40)
color c_ltrig = color.new(lower_trigger_level_color, 40)
color c_utrig = color.new(upper_trigger_level_color, 40)
color c_key   = color.new(key_target_level_color, 40)
color c_atr   = color.new(atr_target_level_color, 40)

// ── Core essentials
plot(ps_on ? prev_close    : na, title="ATR Prev Close",    color=c_pc,    linewidth=1, display=display.price_scale)
plot(ps_on ? lower_trigger : na, title="ATR Lower Trigger", color=c_ltrig, linewidth=1, display=display.price_scale)
plot(ps_on ? upper_trigger : na, title="ATR Upper Trigger", color=c_utrig, linewidth=1, display=display.price_scale)

// ±100%
plot(ps_on ? lower_1000    : na, title="ATR -100%",         color=c_atr,   linewidth=1, display=display.price_scale)
plot(ps_on ? upper_1000    : na, title="ATR +100%",         color=c_atr,   linewidth=1, display=display.price_scale)

// ±38.2%
plot(ps_on ? lower_0382    : na, title="ATR -38.2%",        color=c_key,   linewidth=1, display=display.price_scale)
plot(ps_on ? upper_0382    : na, title="ATR +38.2%",        color=c_key,   linewidth=1, display=display.price_scale)

// ±61.8%
plot(ps_on ? lower_0618    : na, title="ATR -61.8%",        color=c_key,   linewidth=1, display=display.price_scale)
plot(ps_on ? upper_0618    : na, title="ATR +61.8%",        color=c_key,   linewidth=1, display=display.price_scale)

// Key extensions (only when extensions are enabled)
plot(ps_ext ? lower_1618   : na, title="ATR -161.8%",       color=c_key,   linewidth=1, display=display.price_scale)
plot(ps_ext ? upper_1618   : na, title="ATR +161.8%",       color=c_key,   linewidth=1, display=display.price_scale)

plot(ps_ext ? lower_2618   : na, title="ATR -261.8%",       color=c_key,   linewidth=1, display=display.price_scale)
plot(ps_ext ? upper_2618   : na, title="ATR +261.8%",       color=c_key,   linewidth=1, display=display.price_scale)

// ATR target extensions (200 / 300) - commented out to reduce plot count
// plot(ps_ext ? lower_2000   : na, title="ATR -200%",         color=c_atr,   linewidth=1, display=display.price_scale)
// plot(ps_ext ? upper_2000   : na, title="ATR +200%",         color=c_atr,   linewidth=1, display=display.price_scale)
// plot(ps_ext ? lower_3000   : na, title="ATR -300%",         color=c_atr,   linewidth=1, display=display.price_scale)
// plot(ps_ext ? upper_3000   : na, title="ATR +300%",         color=c_atr,   linewidth=1, display=display.price_scale)

// Calculate dynamic proximity threshold based on instrument type
int proximity_threshold = f_get_proximity_threshold()

// ──────────────────────────────────────────────────────────────
// Compression Dots — Chart TF (DOTS ONLY)
// ──────────────────────────────────────────────────────────────
float dotOffset = 0.5 * syminfo.mintick


float compDotY =
     showCompDots and isCompressed_chart
     ? (isUpBar ? (low - dotOffset) : (high + dotOffset))
     : na

plot(
     compDotY,
     title     = "Compression Dot (Chart TF)",
     style     = plot.style_circles,
     color     = color.fuchsia,
     linewidth = 3,
     display   = display.all - display.price_scale)

// ──────────────────────────────────────────────────────────────
// PO Dots — Plot Style Logic
// ──────────────────────────────────────────────────────────────

// Chart TF PO
po_chart = saty_po
[chart_acc, chart_dn, chart_dist, chart_up] = f_po_leave_flags(po_chart)
bool hasChart = (chart_acc or chart_dn or chart_dist or chart_up) and poDots_chart_enable
float poDot_chart =
     hasChart
     ? (chart_acc or chart_dn ? (low - dotOffset) :
        chart_dist or chart_up ? (high + dotOffset) : na)
     : na
plot(
     poDot_chart,
     title     = "PO Dot Chart TF",
     style     = plot.style_circles,
     linewidth = poDots_chart_w,
     color     = poDots_chart_color,
     display   = display.all - display.price_scale)

// ──────────────────────────────────────────────────────────────
// PO Dots — Priority: 30m > 10m > 3m > 1m
// ──────────────────────────────────────────────────────────────

// 30m (only if no Chart TF dot this bar)
po_30m = f_saty_po_tf("30")
[acc30, dn30, dist30, up30] = f_po_leave_flags(po_30m)
bool has30_raw = (acc30 or dn30 or dist30 or up30) and poDots_30m_enable
bool has30 = has30_raw and not hasChart

float poDot_30m =
     has30
     ? (acc30 or dn30 ? (low - dotOffset) :
        dist30 or up30 ? (high + dotOffset) : na)
     : na

// plot(poDot_30m, title="PO Dot 30m", style=plot.style_circles, linewidth=poDots_30m_w, color=poDots_30m_color, display=display.all - display.price_scale)


// 10m (only if no Chart TF or 30m dot this bar)
po_10m = f_saty_po_tf("10")
[acc10, dn10, dist10, up10] = f_po_leave_flags(po_10m)
bool has10_raw = (acc10 or dn10 or dist10 or up10) and poDots_10m_enable
bool has10 = has10_raw and not hasChart and not has30

float poDot_10m =
     has10
     ? (acc10 or dn10 ? (low - dotOffset) :
        dist10 or up10 ? (high + dotOffset) : na)
     : na

// plot(poDot_10m, title="PO Dot 10m", style=plot.style_circles, linewidth=poDots_10m_w, color=poDots_10m_color, display=display.all - display.price_scale)


// 3m (only if no Chart TF dot this bar)
po_3m = f_saty_po_tf("3")
[acc3, dn3, dist3, up3] = f_po_leave_flags(po_3m)
bool has3_raw = (acc3 or dn3 or dist3 or up3) and poDots_3m_enable
bool has3 = has3_raw and not hasChart

float poDot_3m =
     has3
     ? (acc3 or dn3 ? (low - dotOffset) :
        dist3 or up3 ? (high + dotOffset) : na)
     : na

plot(poDot_3m, title="PO Dot 3m", style=plot.style_circles, linewidth=poDots_3m_w, color=poDots_3m_color, display=display.all - display.price_scale)


// 1m (only if no Chart TF or 3m dot this bar)
po_1m = f_saty_po_tf("1")
[acc1, dn1, dist1, up1] = f_po_leave_flags(po_1m)
bool has1_raw = (acc1 or dn1 or dist1 or up1) and poDots_1m_enable
bool has1 = has1_raw and not hasChart and not has3

float poDot_1m =
     has1
     ? (acc1 or dn1 ? (low - dotOffset) :
        dist1 or up1 ? (high + dotOffset) : na)
     : na

plot(poDot_1m, title="PO Dot 1m", style=plot.style_circles, linewidth=poDots_1m_w, color=poDots_1m_color, display=display.all - display.price_scale)
// ──────────────────────────────────────────────────────────────
// RSI(5/14) + Saty Phase Oscillator HUD
// ──────────────────────────────────────────────────────────────

// RSI values
rsi_fast = ta.rsi(close, rsi_fast_len)
rsi_slow = ta.rsi(close, rsi_slow_len)

// ──────────────────────────────────────────────────────────────
// RSI(5) price/RSI divergence (same semantics as RSI indicator)
// ──────────────────────────────────────────────────────────────
int   rsi5_lookbackRight = 5
int   rsi5_lookbackLeft  = 5
int   rsi5_rangeUpper    = 60
int   rsi5_rangeLower    = 5

rsi5_inRange(bool cond) =>
    bars = ta.barssince(cond)
    rsi5_rangeLower <= bars and bars <= rsi5_rangeUpper

// These mirror the RSI script's divergence vars, but scoped to RSI(5)
bool  rsi5_plFound   = false
bool  rsi5_phFound   = false
bool  rsi5_bullCond  = false
bool  rsi5_bearCond  = false

float rsi5_rsiLBR = rsi_fast[rsi5_lookbackRight]

if rsiHud_show_rsi5_div
    // Regular Bullish: price LL, RSI HL
    rsi5_plFound := not na(ta.pivotlow(rsi_fast, rsi5_lookbackLeft, rsi5_lookbackRight))
    float lowLBR = low[rsi5_lookbackRight]
    bool rsi5_inRangePL = rsi5_inRange(rsi5_plFound[1])
    bool rsi5_HL        = rsi5_rsiLBR > ta.valuewhen(rsi5_plFound, rsi5_rsiLBR, 1) and rsi5_inRangePL
    bool priceLL        = lowLBR < ta.valuewhen(rsi5_plFound, lowLBR, 1)
    rsi5_bullCond       := priceLL and rsi5_HL and rsi5_plFound

    // Regular Bearish: price HH, RSI LH
    rsi5_phFound := not na(ta.pivothigh(rsi_fast, rsi5_lookbackLeft, rsi5_lookbackRight))
    float highLBR = high[rsi5_lookbackRight]
    bool rsi5_inRangePH = rsi5_inRange(rsi5_phFound[1])
    bool rsi5_LH        = rsi5_rsiLBR < ta.valuewhen(rsi5_phFound, rsi5_rsiLBR, 1) and rsi5_inRangePH
    bool priceHH        = highLBR > ta.valuewhen(rsi5_phFound, highLBR, 1)
    rsi5_bearCond       := priceHH and rsi5_LH and rsi5_phFound

    // Place emojis on the actual pivot bar (bar_index - lookbackRight)
    if rsi5_bullCond
        f_push_lbl(label.new(
             bar_index - rsi5_lookbackRight, low[rsi5_lookbackRight] - fromTicks(rsiDiv_offsetTicks), "🐂",
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_up,
             size  = rsiDiv_size,
             textcolor = color.new(color.green, 0),
             color     = color.new(color.white, 95)))

    if rsi5_bearCond
        f_push_lbl(label.new(
             bar_index - rsi5_lookbackRight, high[rsi5_lookbackRight] + fromTicks(rsiDiv_offsetTicks), "🐻",
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_down,
             size  = rsiDiv_size,
             textcolor = color.new(color.red, 0),
             color     = color.new(color.white, 95)))


// ──────────────────────────────────────────────────────────────
// Phase Oscillator Divergence (mirror of MTF Phase Oscillator)
// ──────────────────────────────────────────────────────────────
// Match PO panel defaults: Chart TF, divLeft=2, divRight=2, min gap = 5
const int poDiv_left   = 2
const int poDiv_right  = 2
const int poDiv_minGap = 5

// State for last confirmed pivots (price + osc)
var float po_prevLowPx   = na
var float po_prevLowOsc  = na
var int   po_prevLowIdx  = na

var float po_prevHighPx  = na
var float po_prevHighOsc = na
var int   po_prevHighIdx = na

// Per-bar triggers + emoji series we can feed into HUD
var string po_lastEmoji      = ""
string     po_emoji_this_bar = ""

// Source osc for divergence (chart-TF saty_po → matches osc_c when divOnWhich=\"Chart TF\")
oscForDiv_po = saty_po

// --- New LOW pivot (potential bullish divergence)
float po_newLow = ta.pivotlow(low, poDiv_left, poDiv_right)
if not na(po_newLow)
    int   idxL  = bar_index - poDiv_right
    float pxL   = low[poDiv_right]
    float oscL  = oscForDiv_po[poDiv_right]

    if not na(po_prevLowIdx) and (idxL - po_prevLowIdx) >= poDiv_minGap
        bool bullDiv = (pxL < po_prevLowPx) and (oscL > po_prevLowOsc)
        if bullDiv
            if poDiv_show_on_price
                f_push_lbl(label.new(
                     idxL, pxL - fromTicks(poDiv_offsetTicks), "🦬",
                     xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_label_up,
                     size  = poDiv_size,
                     textcolor = color.new(color.green, 0),
                     color     = color.new(color.white, 95)))

    po_prevLowIdx := idxL
    po_prevLowPx  := pxL
    po_prevLowOsc := oscL

// --- New HIGH pivot (potential bearish divergence)
float po_newHigh = ta.pivothigh(high, poDiv_left, poDiv_right)
if not na(po_newHigh)
    int   idxH  = bar_index - poDiv_right
    float pxH   = high[poDiv_right]
    float oscH  = oscForDiv_po[poDiv_right]

    if not na(po_prevHighIdx) and (idxH - po_prevHighIdx) >= poDiv_minGap
        bool bearDiv = (pxH > po_prevHighPx) and (oscH < po_prevHighOsc)
        if bearDiv
            if poDiv_show_on_price
                f_push_lbl(label.new(
                     idxH, pxH + fromTicks(poDiv_offsetTicks), "🧸",
                     xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_label_down,
                     size  = poDiv_size,
                     textcolor = color.new(color.red, 0),
                     color     = color.new(color.white, 95)))

    po_prevHighIdx := idxH
    po_prevHighPx  := pxH
    po_prevHighOsc := oscH

// RSI extreme labels on price (RSI(5) > 85 or < 15)
if rsiExt_enable
    bool rsi_hi = rsi_fast > rsiExt_hi
    bool rsi_lo = rsi_fast < rsiExt_lo

    if rsi_hi
        f_push_lbl(label.new(
             bar_index, high + fromTicks(rsiExt_offsetTicks), "🚨",
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_down,
             size  = rsiExt_size,
             textcolor = color.black,
             color     = color.new(color.white, 95)))

    if rsi_lo
        f_push_lbl(label.new(
             bar_index, low - fromTicks(rsiExt_offsetTicks), "🚨",
             xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_up,
             size  = rsiExt_size,
             textcolor = color.black,
             color     = color.new(color.white, 95)))

// ──────────────────────────────────────────────────────────────
// F) Core Level Lines (steplines using line objects for dynamic width)
// ──────────────────────────────────────────────────────────────
var line[]  coreStep  = array.new_line(13)
var float[] corePrevY = array.new_float(13)

// Core levels array: [level, color, show_condition]
updateCoreStep(int idx, bool show, float y, color col, bool isHighlighted) =>
    ln = array.get(coreStep, idx)
    py = array.get(corePrevY, idx)
    int lineWidth = isHighlighted ? 4 : level_size
    if not show or na(y)
        if not na(ln)
            line.delete(ln)
            ln := na
        array.set(coreStep, idx, ln)
        array.set(corePrevY, idx, na)
    else
        if na(ln) or na(py) or (y != py)
            if not na(ln)
                line.delete(ln)
            ln := line.new(bar_index - 1, y, bar_index, y, xloc=xloc.bar_index, extend=extend.none, color=col, width=lineWidth)
        else
            line.set_xy2(ln, bar_index, y)
            line.set_width(ln, lineWidth)
        array.set(coreStep, idx, ln)
        array.set(corePrevY, idx, y)

// Update core levels
updateCoreStep(0,  show_atr_levels, lower_1000, color.new(atr_target_level_color,40), f_is_near_level(lower_1000, proximity_threshold))
updateCoreStep(1,  show_atr_levels, lower_0786, color.new(intermediate_target_level_color,40), f_is_near_level(lower_0786, proximity_threshold))
updateCoreStep(2,  show_atr_levels, lower_0618, color.new(key_target_level_color,40), f_is_near_level(lower_0618, proximity_threshold))
updateCoreStep(3,  show_atr_levels, lower_0500, color.new(intermediate_target_level_color,40), f_is_near_level(lower_0500, proximity_threshold))
updateCoreStep(4,  show_atr_levels, lower_0382, color.new(intermediate_target_level_color,40), f_is_near_level(lower_0382, proximity_threshold))
updateCoreStep(5,  show_atr_levels, lower_trigger, color.new(lower_trigger_level_color,40), f_is_near_level(lower_trigger, proximity_threshold))
updateCoreStep(6,  show_atr_levels, prev_close, color.new(previous_close_level_color,40), f_is_near_level(prev_close, proximity_threshold))
updateCoreStep(7,  show_atr_levels, upper_trigger, color.new(upper_trigger_level_color,40), f_is_near_level(upper_trigger, proximity_threshold))
updateCoreStep(8,  show_atr_levels, upper_0382, color.new(intermediate_target_level_color,40), f_is_near_level(upper_0382, proximity_threshold))
updateCoreStep(9,  show_atr_levels, upper_0500, color.new(intermediate_target_level_color,40), f_is_near_level(upper_0500, proximity_threshold))
updateCoreStep(10, show_atr_levels, upper_0618, color.new(key_target_level_color,40), f_is_near_level(upper_0618, proximity_threshold))
updateCoreStep(11, show_atr_levels, upper_0786, color.new(intermediate_target_level_color,40), f_is_near_level(upper_0786, proximity_threshold))
updateCoreStep(12, show_atr_levels, upper_1000, color.new(atr_target_level_color,40), f_is_near_level(upper_1000, proximity_threshold))

// ──────────────────────────────────────────────────────────────
// G) Extension Levels as STEPLINES using line objects (not plots)
// ──────────────────────────────────────────────────────────────
var line[]  extStep  = array.new_line(18)
var float[] extPrevY = array.new_float(18)

newStep(y, col, w) =>
    line.new(bar_index - 1, y, bar_index, y,        xloc=xloc.bar_index, extend=extend.none, color=col, width=w)

updateStep(int idx, bool show, float y, color col, bool isHighlighted) =>
    ln = array.get(extStep, idx)
    py = array.get(extPrevY, idx)
    int lineWidth = isHighlighted ? 4 : level_size
    if not show or na(y)
        if not na(ln)
            line.delete(ln)
            ln := na
        array.set(extStep, idx, ln)
        array.set(extPrevY, idx, na)
    else
        if na(ln) or na(py) or (y != py)
            if not na(ln)
                line.delete(ln)
            ln := newStep(y, col, lineWidth)
        else
            line.set_xy2(ln, bar_index, y)
            line.set_width(ln, lineWidth)
        array.set(extStep, idx, ln)
        array.set(extPrevY, idx, y)

// Map levels
updateStep(0,  show_atr_levels and show_extensions,                          upper_1236, key_target_level_color, f_is_near_level(upper_1236, proximity_threshold))
updateStep(1,  show_atr_levels and show_extensions and show_all_fibonacci_levels, upper_1382, intermediate_target_level_color, f_is_near_level(upper_1382, proximity_threshold))
updateStep(2,  show_atr_levels and show_extensions and show_all_fibonacci_levels, upper_1500, intermediate_target_level_color, f_is_near_level(upper_1500, proximity_threshold))
updateStep(3,  show_atr_levels and show_extensions,                          upper_1618, key_target_level_color, f_is_near_level(upper_1618, proximity_threshold))
updateStep(4,  show_atr_levels and show_extensions and show_all_fibonacci_levels, upper_1786, intermediate_target_level_color, f_is_near_level(upper_1786, proximity_threshold))
updateStep(5,  show_atr_levels and show_extensions,                          upper_2000, atr_target_level_color, f_is_near_level(upper_2000, proximity_threshold))
updateStep(6,  show_atr_levels and show_extensions,                          upper_2236, key_target_level_color, f_is_near_level(upper_2236, proximity_threshold))
updateStep(7,  show_atr_levels and show_extensions,                          upper_2618, key_target_level_color, f_is_near_level(upper_2618, proximity_threshold))
updateStep(8,  show_atr_levels and show_extensions,                          upper_3000, atr_target_level_color, f_is_near_level(upper_3000, proximity_threshold))
updateStep(9,  show_atr_levels and show_extensions,                          lower_1236, key_target_level_color, f_is_near_level(lower_1236, proximity_threshold))
updateStep(10, show_atr_levels and show_extensions and show_all_fibonacci_levels, lower_1382, intermediate_target_level_color, f_is_near_level(lower_1382, proximity_threshold))
updateStep(11, show_atr_levels and show_extensions and show_all_fibonacci_levels, lower_1500, intermediate_target_level_color, f_is_near_level(lower_1500, proximity_threshold))
updateStep(12, show_atr_levels and show_extensions,                          lower_1618, key_target_level_color, f_is_near_level(lower_1618, proximity_threshold))
updateStep(13, show_atr_levels and show_extensions and show_all_fibonacci_levels, lower_1786, intermediate_target_level_color, f_is_near_level(lower_1786, proximity_threshold))
updateStep(14, show_atr_levels and show_extensions,                          lower_2000, atr_target_level_color, f_is_near_level(lower_2000, proximity_threshold))
updateStep(15, show_atr_levels and show_extensions,                          lower_2236, key_target_level_color, f_is_near_level(lower_2236, proximity_threshold))
updateStep(16, show_atr_levels and show_extensions,                          lower_2618, key_target_level_color, f_is_near_level(lower_2618, proximity_threshold))
updateStep(17, show_atr_levels and show_extensions,                          lower_3000, atr_target_level_color, f_is_near_level(lower_3000, proximity_threshold))

// ──────────────────────────────────────────────────────────────
// H) Right-edge tags — ALL levels (REUSE labels; mobile-safe)
// ──────────────────────────────────────────────────────────────

// Helper: create/update one label (no delete/recreate churn)
f_tag_upd(label lb, bool on, float y, string txt, bool isHighlighted) =>
    // Always return a LABEL-typed value
    label out = lb

    if not tags_enable or not on or na(y)
        if not na(out)
            label.delete(out)
        out := na
    else
        int   x_  = bar_index + tags_right_bars
        float y_  = y + fromTicks(tags_y_offset_ticks)
        
        // Tags show only the level name (price shown separately on price scale)
        string displayText = txt
        
        // Dynamic colors based on highlight state
        color bgColor = isHighlighted ? color.black : color.new(tags_bg_color, tags_bg_alpha)
        color txtColor = isHighlighted ? color.white : tags_text_color_cfg

        if na(out)
            out := label.new(
                 x_, y_, displayText,
                 xloc=xloc.bar_index, yloc=yloc.price,
                 style=(tags_point_left ? label.style_label_left : label.style_label_right),
                 size=lbl_size(tags_text_size),
                 color=bgColor,
                 textcolor=txtColor)
        else
            label.set_x(out, x_)
            label.set_y(out, y_)
            label.set_text(out, displayText)
            label.set_style(out, (tags_point_left ? label.style_label_left : label.style_label_right))
            label.set_size(out, lbl_size(tags_text_size))
            label.set_color(out, bgColor)
            label.set_textcolor(out, txtColor)

    out

// One var label per tag (only created if enabled)
var label t_u100  = na
var label t_u786  = na
var label t_u618  = na
var label t_u500  = na
var label t_u382  = na
var label t_utrig = na
var label t_pc    = na

var label t_u1236 = na

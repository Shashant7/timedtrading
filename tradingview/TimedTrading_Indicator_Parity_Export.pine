//@version=6
indicator("TimedTrading Indicator Parity Export", overlay=false, max_bars_back=5000)

// Shadow-only benchmark exporter for docs/active-trader-information-hardening-plan.md.
//
// Usage:
// 1. Add to the chart for ONE ticker and ONE timeframe.
// 2. Make sure chart session matches fixture policy:
//    - 5/10/15/30m equities: Extended Hours enabled
//    - 60/240: RTH
//    - D/W/M: exchange-session bars
//    - ORB columns are meaningful only on intraday RTH charts
// 3. TradingView menu → Export chart data.
// 4. Save the CSV as ticker_tf_range.csv and send it back for fixture conversion.
//
// Numeric code legends:
// phase_zone_code / saty_phase_zone_code: 0=LOW, 1=MEDIUM, 2=HIGH, 3=EXTREME
// pdz_zone_code: 0=discount, 1=discount_approach, 2=equilibrium, 3=premium_approach, 4=premium
// td_tv_side_code: -1=bear, 0=none, 1=bull
// supertrend_dir: -1=bullish support, +1=bearish resistance (matches worker)
// orb_15m_direction: -1=breakdown, 0=none, 1=breakout

groupCore = "Core settings"
stFactor = input.float(3.0, "SuperTrend factor", step=0.1, group=groupCore)
stAtrLen = input.int(10, "SuperTrend ATR length", minval=1, group=groupCore)
pdzLookback = input.int(50, "PDZ lookback", minval=20, maxval=200, group=groupCore)
fvgLookback = input.int(80, "FVG scan lookback", minval=10, maxval=150, group=groupCore)
liqLookback = input.int(50, "Liquidity proxy lookback", minval=10, maxval=200, group=groupCore)

f_bool(x) => x ? 1.0 : 0.0

f_phase_zone_code(v) =>
    a = math.abs(v)
    a > 100 ? 3 : a > 61.8 ? 2 : a > 38.2 ? 1 : 0

f_pdz_zone_code(px, hi, lo) =>
    rng = hi - lo
    premiumLine = lo + 0.95 * rng
    discountLine = lo + 0.05 * rng
    eqHigh = lo + 0.525 * rng
    eqLow = lo + 0.475 * rng
    px <= discountLine ? 0 : px < eqLow ? 1 : px <= eqHigh ? 2 : px < premiumLine ? 3 : 4

// Core OHLC / standard indicators
ema21 = ta.ema(close, 21)
ema200 = ta.ema(close, 200)
rsi14 = ta.rsi(close, 14)
atr14 = ta.atr(14)

// Worker-compatible SuperTrend sign convention: -1 bullish support, +1 bearish resistance.
atrSt = ta.atr(stAtrLen)
upperRaw = hl2 + stFactor * atrSt
lowerRaw = hl2 - stFactor * atrSt
var float stUpper = na
var float stLower = na
var float stLine = na
var int stDir = 0
if bar_index == stAtrLen and not na(atrSt)
    stDir := -1
    stUpper := upperRaw
    stLower := lowerRaw
    stLine := lowerRaw
else if bar_index > stAtrLen and not na(atrSt)
    stLower := not na(stLower[1]) and lowerRaw < stLower[1] and close[1] > stLower[1] ? stLower[1] : lowerRaw
    stUpper := not na(stUpper[1]) and upperRaw > stUpper[1] and close[1] < stUpper[1] ? stUpper[1] : upperRaw
    prevDir = nz(stDir[1], -1)
    if prevDir == -1
        stDir := close < stLower ? 1 : -1
        stLine := stDir == -1 ? stLower : stUpper
    else
        stDir := close > stUpper ? -1 : 1
        stLine := stDir == -1 ? stLower : stUpper

// TTM squeeze (same BB/KC parameters as worker bundle)
sqLen = 20
bbMult = 2.0
kcMult = 1.5
sqBasis = ta.sma(close, sqLen)
sqDev = ta.stdev(close, sqLen)
sqAtr = ta.atr(sqLen)
bbU = sqBasis + bbMult * sqDev
bbL = sqBasis - bbMult * sqDev
kcU = sqBasis + kcMult * sqAtr
kcL = sqBasis - kcMult * sqAtr
sqOn = bbU < kcU and bbL > kcL
sqRelease = sqOn[1] and not sqOn

// Momentum and phase. `phase_value` mirrors the worker's current multi-factor
// phase approximation. `saty_phase_value` is the smoothed price-displacement
// oscillator used for leaving-zone tests.
momLen = 20
sma20 = ta.sma(close, momLen)
momDiff = close - sma20
mom = ta.linreg(momDiff, momLen, 0)
momStd = ta.stdev(nz(mom, 0), 20)
volSma20 = ta.sma(volume, 20)
rvol = volSma20 > 0 and volume > 0 ? volume / volSma20 : 1.0
pricePhase = atr14 > 0 and not na(ema21) ? ((close - ema21) / (3.0 * atr14)) * 100.0 : 0.0
momentumPhase = momStd > 0 ? (mom / momStd) * 20.0 : 0.0
volumePhase = (rvol - 1.0) * 30.0
phaseValue = pricePhase * 0.6 + momentumPhase * 0.3 + volumePhase * 0.1
phaseZoneCode = f_phase_zone_code(phaseValue)
satyRaw = atr14 > 0 and not na(ema21) ? ((close - ema21) / (3.0 * atr14)) * 100.0 : 0.0
satyPhase = ta.ema(satyRaw, 3)
satyZoneCode = f_phase_zone_code(satyPhase)
phaseLeavingAccum = satyPhase[1] <= -61.8 and satyPhase > -61.8
phaseLeavingDistribution = satyPhase[1] >= 61.8 and satyPhase < 61.8

// TD Sequential / DeMark setup and countdown, with worker-compatible counters.
var int bullPrep = 0
var int bearPrep = 0
var int bullLead = 0
var int bearLead = 0
var int tvBull = 0
var int tvBear = 0
var int prevRegime = 0
if bar_index >= 4
    bullPrep := close < close[4] ? bullPrep + 1 : 0
    bearPrep := close > close[4] ? bearPrep + 1 : 0
    regime = na(ema21) ? prevRegime : close > ema21 ? 1 : close < ema21 ? -1 : prevRegime
    if regime != 0 and prevRegime != 0 and regime != prevRegime
        tvBull := 0
        tvBear := 0
    if regime == 1
        tvBull := close > close[4] ? tvBull + 1 : 0
        tvBear := 0
    else if regime == -1
        tvBear := close < close[4] ? tvBear + 1 : 0
        tvBull := 0
    prevRegime := regime != 0 ? regime : prevRegime
    bullPrepComplete = bullPrep == 9
    bearPrepComplete = bearPrep == 9
    if bearPrepComplete
        bullLead := 0
    else if bullPrepComplete
        bullLead := 1
    else if bar_index >= 2
        if bullLead > 0 and close < low[2]
            bullLead += 1

    if bullPrepComplete
        bearLead := 0
    else if bearPrepComplete
        bearLead := 1
    else if bar_index >= 2
        if bearLead > 0 and close > high[2]
            bearLead += 1

td9Bull = bullPrep == 9
td9Bear = bearPrep == 9
td13Bull = bullLead == 13
td13Bear = bearLead == 13
tdTvSideCode = tvBull > 0 ? 1 : tvBear > 0 ? -1 : 0

// PDZ: premium / discount over recent swing high-low range.
pdzHi = ta.highest(high, pdzLookback)
pdzLo = ta.lowest(low, pdzLookback)
pdzRange = pdzHi - pdzLo
pdzPosition = pdzRange > 0 ? math.max(0.0, math.min(100.0, ((close - pdzLo) / pdzRange) * 100.0)) : na
pdzZoneCode = pdzRange > 0 ? f_pdz_zone_code(close, pdzHi, pdzLo) : na

// VWAP: cumulative and distance percent.
typ = (high + low + close) / 3.0
cumPv = ta.cum(typ * (volume == 0 ? 1 : volume))
cumV = ta.cum(volume == 0 ? 1 : volume)
vwapCum = cumV > 0 ? cumPv / cumV : na
vwapDistPct = vwapCum > 0 ? ((close - vwapCum) / vwapCum) * 100.0 : na
rollingPv20 = ta.sma(typ * (volume == 0 ? 1 : volume), 20) * 20
rollingV20 = ta.sma(volume == 0 ? 1 : volume, 20) * 20
vwapRolling20 = rollingV20 > 0 ? rollingPv20 / rollingV20 : na
vwapRolling20DistPct = vwapRolling20 > 0 ? ((close - vwapRolling20) / vwapRolling20) * 100.0 : na

// FVG: recent active gap / current price in gap. Numeric proxy for fixture export.
var int activeBullFvg = 0
var int activeBearFvg = 0
var bool inBullFvg = false
var bool inBearFvg = false
activeBullFvg := 0
activeBearFvg := 0
inBullFvg := false
inBearFvg := false
for k = 0 to fvgLookback - 3
    if not na(low[k + 2]) and not na(high[k + 2])
        bullGap = low[k] > high[k + 2]
        bearGap = high[k] < low[k + 2]
        if bullGap
            top = low[k]
            bottom = high[k + 2]
            mitigated = false
            if k > 0
                for j = 0 to k - 1
                    if low[j] <= bottom
                        mitigated := true
            if not mitigated
                activeBullFvg += 1
                inBullFvg := inBullFvg or (close <= top and close >= bottom)
        if bearGap
            topB = low[k + 2]
            bottomB = high[k]
            mitigatedB = false
            if k > 0
                for j = 0 to k - 1
                    if high[j] >= topB
                        mitigatedB := true
            if not mitigatedB
                activeBearFvg += 1
                inBearFvg := inBearFvg or (close <= topB and close >= bottomB)

// Liquidity proxy: distance to unswept recent high/low and sweep flags.
priorHigh = ta.highest(high[1], liqLookback)
priorLow = ta.lowest(low[1], liqLookback)
liqBuysideDistAtr = atr14 > 0 ? (priorHigh - close) / atr14 : na
liqSellsideDistAtr = atr14 > 0 ? (close - priorLow) / atr14 : na
liqBuysideSwept = high > priorHigh
liqSellsideSwept = low < priorLow

// ORB 15m direction. Meaningful only on intraday charts with RTH bars.
nyHour = hour(time, "America/New_York")
nyMin = minute(time, "America/New_York")
nyTotal = nyHour * 60 + nyMin
newDay = ta.change(time("D")) != 0
inOrb15 = nyTotal >= 570 and nyTotal < 585
afterOrb15 = nyTotal >= 585
var float orb15High = na
var float orb15Low = na
if newDay
    orb15High := na
    orb15Low := na
if inOrb15
    orb15High := na(orb15High) ? high : math.max(orb15High, high)
    orb15Low := na(orb15Low) ? low : math.min(orb15Low, low)
orb15Direction = afterOrb15 and not na(orb15High) and close > orb15High ? 1 : afterOrb15 and not na(orb15Low) and close < orb15Low ? -1 : 0

// RSI divergence proxy: pivot-based flags using TradingView pivots.
rsiPivotLow = ta.pivotlow(rsi14, 5, 5)
rsiPivotHigh = ta.pivothigh(rsi14, 5, 5)
pricePivotLow = ta.pivotlow(low, 5, 5)
pricePivotHigh = ta.pivothigh(high, 5, 5)
prevRsiLow = ta.valuewhen(not na(rsiPivotLow), rsiPivotLow, 1)
prevPriceLow = ta.valuewhen(not na(pricePivotLow), pricePivotLow, 1)
prevRsiHigh = ta.valuewhen(not na(rsiPivotHigh), rsiPivotHigh, 1)
prevPriceHigh = ta.valuewhen(not na(pricePivotHigh), pricePivotHigh, 1)
rsiBullDiv = not na(rsiPivotLow) and not na(prevRsiLow) and not na(prevPriceLow) and pricePivotLow < prevPriceLow and rsiPivotLow > prevRsiLow
rsiBearDiv = not na(rsiPivotHigh) and not na(prevRsiHigh) and not na(prevPriceHigh) and pricePivotHigh > prevPriceHigh and rsiPivotHigh < prevRsiHigh

// Plot every benchmark column so TradingView's "Export chart data" includes it.
plot(close, "close")
plot(open, "open")
plot(high, "high")
plot(low, "low")
plot(volume, "volume")
plot(ema21, "ema21")
plot(ema200, "ema200")
plot(rsi14, "rsi14")
plot(atr14, "atr14")
plot(stDir, "supertrend_dir")
plot(stLine, "supertrend_line")
plot(f_bool(td9Bull), "td9_bull")
plot(f_bool(td9Bear), "td9_bear")
plot(f_bool(td13Bull), "td13_bull")
plot(f_bool(td13Bear), "td13_bear")
plot(bullPrep, "td_bull_prep_count")
plot(bearPrep, "td_bear_prep_count")
plot(bullLead, "td_bull_leadup_count")
plot(bearLead, "td_bear_leadup_count")
plot(tvBull > 0 ? tvBull : tvBear > 0 ? tvBear : 0, "td_tv_count")
plot(tdTvSideCode, "td_tv_side_code")
plot(phaseValue, "phase_value")
plot(phaseZoneCode, "phase_zone_code")
plot(satyPhase, "saty_phase_value")
plot(satyZoneCode, "saty_phase_zone_code")
plot(f_bool(phaseLeavingAccum), "phase_leaving_accum")
plot(f_bool(phaseLeavingDistribution), "phase_leaving_distribution")
plot(f_bool(sqOn), "sq_on")
plot(f_bool(sqRelease), "sq_release")
plot(vwapCum, "vwap")
plot(vwapDistPct, "vwap_dist_pct")
plot(vwapRolling20, "vwap_rolling20")
plot(vwapRolling20DistPct, "vwap_rolling20_dist_pct")
plot(rvol, "rvol")
plot(pdzPosition, "pdz_position")
plot(pdzZoneCode, "pdz_zone_code")
plot(activeBullFvg, "fvg_active_bull")
plot(activeBearFvg, "fvg_active_bear")
plot(f_bool(inBullFvg), "fvg_in_bull")
plot(f_bool(inBearFvg), "fvg_in_bear")
plot(liqBuysideDistAtr, "liq_nearest_bs_dist_atr")
plot(liqSellsideDistAtr, "liq_nearest_ss_dist_atr")
plot(f_bool(liqBuysideSwept), "liq_buyside_swept")
plot(f_bool(liqSellsideSwept), "liq_sellside_swept")
plot(orb15Direction, "orb_15m_direction")
plot(f_bool(rsiBullDiv), "rsi_bull_divergence")
plot(f_bool(rsiBearDiv), "rsi_bear_divergence")

